# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=Elevra
DEBUG=false
API_V1_PREFIX=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your_db_password@localhost:5432/careerai

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── AI provider key ───────────────────────────────────────────────────────────
# Anthropic keys start with: sk-ant-
# Gemini keys start with:    AIza
AI_API_KEY=
CLAUDE_MODEL=claude-3-5-sonnet-20241022
GEMINI_MODEL=gemini-2.5-flash

# ── Storage (DigitalOcean Spaces / S3) ───────────────────────────────────────
SPACES_KEY=
SPACES_SECRET=
SPACES_REGION=blr1
SPACES_BUCKET=careerai-media
SPACES_ENDPOINT=https://blr1.digitaloceanspaces.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: https://elevraa.me
# Local dev:  http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ── JSearch Job API (RapidAPI) ────────────────────────────────────────────────
RAPIDAPI_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=change-me-to-a-random-secret

# ── IPQualityScore (disposable email detection) ───────────────────────────────
IPQS_API_KEY=
